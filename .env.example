# Telegram Bot Token（从 @BotFather 获取，必填）
BOT_TOKEN=your_bot_token_here

# 管理员 Telegram User ID（多个用逗号分隔，可选）
ADMIN_IDS=123456789,987654321

# 数据库类型：sqlite（本地开发）或 postgres（Railway 生产）
DB_TYPE=sqlite

# SQLite 数据库路径（DB_TYPE=sqlite 时使用）
DB_PATH=attendance.db

# PostgreSQL 连接串（DB_TYPE=postgres 时使用，Railway 自动注入）
DATABASE_URL=postgresql://user:pass@host:5432/db
